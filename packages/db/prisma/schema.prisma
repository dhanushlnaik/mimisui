generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model DiscordUser {
  id             String         @id
  username       String
  avatar         String?
  relationshipsA Relationship[] @relation("UserOne")
  relationshipsB Relationship[] @relation("UserTwo")
  socialLinksA   SocialRelationship[] @relation("SocialUserA")
  socialLinksB   SocialRelationship[] @relation("SocialUserB")
  socialEvents   SocialRelationshipEvent[]
  socialProposalsSent SocialProposal[] @relation("ProposalSender")
  socialProposalsReceived SocialProposal[] @relation("ProposalTarget")
  afk            AFK?
  todos          Todo[]
  progress       UserProgress?
  boosters       Booster[]
  quests         UserQuest[]
  transactions   Transaction[]
  familyQuestClaims FamilyQuestClaim[]
  relationshipItems RelationshipInventory[]
  familyAchievementClaims FamilyAchievementClaim[]
  familySeasonClaims FamilySeasonClaim[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Guild {
  id        String   @id
  name      String?
  prefix    String   @default("!")
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AFK {
  userId      String   @id
  guildId     String
  reason      String
  mentionCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user DiscordUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

model Relationship {
  id        String   @id @default(cuid())
  guildId   String
  user1Id   String
  user2Id   String
  type      String
  score     Int      @default(0)
  createdAt DateTime @default(now())

  user1 DiscordUser @relation("UserOne", fields: [user1Id], references: [id], onDelete: Cascade)
  user2 DiscordUser @relation("UserTwo", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([guildId, user1Id, user2Id, type])
  @@index([guildId])
}

model Todo {
  id        String   @id @default(cuid())
  userId    String
  guildId   String?
  content   String
  createdAt DateTime @default(now())

  user DiscordUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

model UserProgress {
  userId           String   @id
  guildId          String?
  xp               Int      @default(0)
  level            Int      @default(1)
  coins            Int      @default(0)
  title            String   @default("Beginner")
  dailyStreak      Int      @default(0)
  lastXpAt         DateTime?
  xpMinuteBucket   DateTime?
  xpMinuteGained   Int      @default(0)
  firstCommandDate String?
  lastDailyClaimDate String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user DiscordUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

model Booster {
  id         String   @id @default(cuid())
  userId     String
  guildId    String?
  type       String
  multiplier Float
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user DiscordUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserQuest {
  id          String   @id @default(cuid())
  userId      String
  guildId     String?
  type        String
  action      String
  target      Int
  progress    Int      @default(0)
  rewardXP    Int
  rewardCoins Int
  completed   Boolean  @default(false)
  claimed     Boolean  @default(false)
  periodKey   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user DiscordUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, guildId, type, action, periodKey])
  @@index([type, periodKey])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  guildId   String?
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  user DiscordUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SocialRelationship {
  id            String             @id @default(cuid())
  type          RelationshipType
  status        RelationshipStatus @default(ACTIVE)
  userAId       String
  userBId       String
  userLowId     String
  userHighId    String
  guildOriginId String?
  startedAt     DateTime           @default(now())
  endedAt       DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  progress SocialRelationshipProgress?
  events SocialRelationshipEvent[]

  leftUser  DiscordUser @relation("SocialUserA", fields: [userAId], references: [id], onDelete: Cascade)
  rightUser DiscordUser @relation("SocialUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([type, userLowId, userHighId])
  @@index([type, status])
  @@index([userAId, status])
  @@index([userBId, status])
}

model SocialRelationshipProgress {
  relationshipId       String   @id
  bondXp               Int      @default(0)
  bondLevel            Int      @default(1)
  bondScore            Int      @default(0)
  totalDates           Int      @default(0)
  currentStreak        Int      @default(0)
  bestStreak           Int      @default(0)
  sharedCoins          Int      @default(0)
  questsCompleted      Int      @default(0)
  anniversaryClaimedAt DateTime?
  lastDateAt           DateTime?
  lastSimulationAt     DateTime?
  simWinStreak         Int      @default(0)
  simBestWinStreak     Int      @default(0)
  simMilestoneMask     Int      @default(0)
  simSeasonKey         String?
  simSeasonPoints      Int      @default(0)
  simSeasonTier        String   @default("UNRANKED")
  simSeasonRewardMask  Int      @default(0)
  simDuelLockedUntil   DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  relationship SocialRelationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
}

model SocialRelationshipEvent {
  id             String                @id @default(cuid())
  relationshipId String
  eventType      RelationshipEventType
  actorUserId    String
  metadata       Json?
  createdAt      DateTime              @default(now())

  relationship SocialRelationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  actor        DiscordUser        @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([relationshipId, createdAt])
}

model SocialProposal {
  id          String             @id @default(cuid())
  type        RelationshipType
  fromUserId  String
  toUserId    String
  guildId     String?
  status      RelationshipStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  fromUser DiscordUser @relation("ProposalSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   DiscordUser @relation("ProposalTarget", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, status])
  @@index([fromUserId, status])
  @@index([expiresAt])
}

model FamilyQuestClaim {
  id         String   @id @default(cuid())
  userId     String
  guildId    String?
  questKey   String
  periodKey  String
  questType  String
  rewardXP   Int
  rewardCoins Int
  rewardBondXp Int @default(0)
  createdAt  DateTime @default(now())

  user DiscordUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, guildId, questKey, periodKey])
  @@index([userId, periodKey])
}

model RelationshipInventory {
  id        String   @id @default(cuid())
  userId    String
  itemCode  String
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user DiscordUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemCode])
  @@index([userId])
}

model FamilyAchievementClaim {
  id          String   @id @default(cuid())
  userId      String
  guildId     String?
  achievementKey String
  rewardXP    Int
  rewardCoins Int
  rewardBondXp Int @default(0)
  createdAt   DateTime @default(now())

  user DiscordUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, guildId, achievementKey])
  @@index([userId, createdAt])
}

model FamilySeasonClaim {
  id             String   @id @default(cuid())
  userId         String
  guildId        String?
  seasonKey      String
  relationshipId String
  tier           String
  rank           Int?
  rewardXP       Int
  rewardCoins    Int
  rewardBondXp   Int @default(0)
  claimedAt      DateTime @default(now())

  user DiscordUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonKey, relationshipId])
  @@index([seasonKey, claimedAt])
  @@index([userId, claimedAt])
}

model FamilyPenaltyFlag {
  id             String   @id @default(cuid())
  guildId        String?
  relationshipId String?
  userId         String?
  flagType       String
  reason         String
  penaltyScore   Int      @default(1)
  active         Boolean  @default(true)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  resolvedAt     DateTime?

  @@index([active, createdAt])
  @@index([flagType, createdAt])
  @@index([relationshipId, createdAt])
  @@index([userId, createdAt])
}

model FamilyModerationLog {
  id             String   @id @default(cuid())
  guildId        String?
  relationshipId String?
  userId         String?
  action         String
  severity       String   @default("INFO")
  details        Json?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([severity, createdAt])
  @@index([relationshipId, createdAt])
  @@index([userId, createdAt])
}

enum RelationshipType {
  PARTNER
  SIBLING
}

enum RelationshipStatus {
  PENDING
  ACTIVE
  ENDED
}

enum RelationshipEventType {
  PROPOSED
  ACCEPTED
  REJECTED
  DIVORCED
  DATE_COMPLETED
  ACTION_BOND_BOOST
  SIMULATION_COMPLETED
  DUEL_COMPLETED
  STREAK_UPDATED
  QUEST_COMPLETED
  ANNIVERSARY_CLAIMED
}
